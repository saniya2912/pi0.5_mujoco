                    <body name="right_lower_forearm" pos="0.01 0 0.2707" euler="-1.5708 -1.5708 0">
                      <inertial pos="0.06041 0.00697 0.006" mass="1.60979"
                                fullinertia="0.00387607152 0.00700537914 0.0055275524
                                             -0.00044384784 -0.00021115038  0.00015348067"/>
                      <geom class="visual"    name="rlf_v" type="mesh"     mesh="W1"  rgba="0.5 0.1 0.1 1"/>
                      <geom class="collision" name="rlf_c" type="cylinder" size="0.06 0.05"/>
                      <joint name="right_w1" type="hinge" axis="0 0 1" range="-1.5708 2.094"/>

                      <body name="right_wrist" pos="0.115975 0 0" euler="1.5708 0 1.5708">
