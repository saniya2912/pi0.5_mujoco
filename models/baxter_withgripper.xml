                            fullinertia="0.00711582686 0.01318227876 0.00926852064
                                         0.00036036173  0.0007459496  -0.00019663418"/>
                  <geom class="visual"    name="rle_v" type="mesh"     mesh="E1"  rgba="0.5 0.1 0.1 1"/>
