                    <geom class="visual"    name="ruf_v" type="mesh"     mesh="W0"  rgba="0.5 0.1 0.1 1"/>
                    <geom class="collision" name="ruf_c" type="cylinder" size="0.06 0.044" pos="0 0 -0.044"/>
