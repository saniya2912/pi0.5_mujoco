  <!-- ================================================================
    ACTUATORS

    Arm joints : velocity-controlled (kv=30 shoulder/elbow, kv=10 wrist)
    Gripper    : position-controlled (kp=1000, ±20 N)
                 ctrlrange = joint range for each finger

    qpos/ctrl order:
      head_pan | right arm (s0..w2) | right gripper (l,r) | left arm (s0..w2) | left gripper (l,r)
  ================================================================ -->
  <actuator>
    <!-- Head -->
    <velocity name="head_pan_v"  joint="head_pan"  kv="5"  ctrlrange="-1.0 1.0"/>

    <!-- Right arm -->
    <velocity name="right_s0_v"  joint="right_s0"  kv="30" ctrlrange="-3.0 3.0"/>
    <velocity name="right_s1_v"  joint="right_s1"  kv="30" ctrlrange="-3.0 3.0"/>
    <velocity name="right_e0_v"  joint="right_e0"  kv="30" ctrlrange="-3.0 3.0"/>
    <velocity name="right_e1_v"  joint="right_e1"  kv="30" ctrlrange="-3.0 3.0"/>
    <velocity name="right_w0_v"  joint="right_w0"  kv="10" ctrlrange="-4.0 4.0"/>
    <velocity name="right_w1_v"  joint="right_w1"  kv="10" ctrlrange="-4.0 4.0"/>
    <velocity name="right_w2_v"  joint="right_w2"  kv="10" ctrlrange="-4.0 4.0"/>

    <!-- Right gripper fingers (position-controlled) -->
    <position name="right_gripper_l" joint="right_l_finger_joint"
              kp="1000" forcelimited="true" forcerange="-20 20"
              ctrllimited="true" ctrlrange="-0.0115 0.020833"/>
    <position name="right_gripper_r" joint="right_r_finger_joint"
              kp="1000" forcelimited="true" forcerange="-20 20"
              ctrllimited="true" ctrlrange="-0.020833 0.0115"/>

    <!-- Left arm -->
    <velocity name="left_s0_v"   joint="left_s0"   kv="30" ctrlrange="-3.0 3.0"/>
    <velocity name="left_s1_v"   joint="left_s1"   kv="30" ctrlrange="-3.0 3.0"/>
    <velocity name="left_e0_v"   joint="left_e0"   kv="30" ctrlrange="-3.0 3.0"/>
    <velocity name="left_e1_v"   joint="left_e1"   kv="30" ctrlrange="-3.0 3.0"/>
    <velocity name="left_w0_v"   joint="left_w0"   kv="10" ctrlrange="-4.0 4.0"/>
    <velocity name="left_w1_v"   joint="left_w1"   kv="10" ctrlrange="-4.0 4.0"/>
    <velocity name="left_w2_v"   joint="left_w2"   kv="10" ctrlrange="-4.0 4.0"/>

    <!-- Left gripper fingers (position-controlled) -->
    <position name="left_gripper_l" joint="left_l_finger_joint"
              kp="1000" forcelimited="true" forcerange="-20 20"
              ctrllimited="true" ctrlrange="-0.0115 0.020833"/>
    <position name="left_gripper_r" joint="left_r_finger_joint"
              kp="1000" forcelimited="true" forcerange="-20 20"
              ctrllimited="true" ctrlrange="-0.020833 0.0115"/>
  </actuator>

  <!-- ================================================================
    KEYFRAME — "home" pose, both grippers fully open.

    qpos (26 values):
      cube_free (7): x y z qw qx qy qz
      head_pan  (1): 0
      right arm (7): s0 s1 e0 e1 w0 w1 w2
      right grip(2): l_finger r_finger  (open = +0.020833 / -0.020833)
      left arm  (7): s0 s1 e0 e1 w0 w1 w2
      left grip (2): l_finger r_finger  (open = +0.020833 / -0.020833)
  ================================================================ -->
  <keyframe>
    <key name="home"
         qpos="0.65 -0.20 0.525 1 0 0 0
               0
               0 -0.9599 0 2.0 0 0.7854 0   0.020833 -0.020833
               0 -0.9599 0 2.0 0 0.7854 0   0.020833 -0.020833"/>
  </keyframe>

  <!-- ================================================================
    SENSORS — force/torque at each wrist
  ================================================================ -->
  <sensor>
    <force  name="right_force_ee"  site="right_ft_frame"/>
    <torque name="right_torque_ee" site="right_ft_frame"/>
    <force  name="left_force_ee"   site="left_ft_frame"/>
    <torque name="left_torque_ee"  site="left_ft_frame"/>
  </sensor>

