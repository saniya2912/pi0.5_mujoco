<!-- ============================================================================
  baxter_withgripper.xml — MuJoCo MJCF for Baxter robot with Rethink parallel-jaw grippers

  Base model : baxter.xml (converted from Rethink Robotics URDF)
  Grippers   : Rethink Electric Parallel Jaw Gripper (from robosuite)

  Joint tree  (depth-first qpos order):
    [0]  head_pan
    [1]  right_s0  [2] right_s1  [3] right_e0  [4] right_e1
    [5]  right_w0  [6] right_w1  [7] right_w2
    [8]  right_l_finger_joint  [9]  right_r_finger_joint
    [10] left_s0  [11] left_s1  [12] left_e0  [13] left_e1
    [14] left_w0  [15] left_w1  [16] left_w2
    [17] left_l_finger_joint   [18] left_r_finger_joint

  Actuators: velocity-controlled for arm joints (kv=30/10);
             position-controlled for gripper joints (kp=1000, ±20 N).
  Cameras  : head_camera, right_hand_camera, left_hand_camera.
  Keyframe : "home" — natural bent-arm pose, both grippers fully open.
============================================================================ -->
<mujoco model="baxter_withgripper">

  <!-- meshdir is relative to the location of this XML file (models/) -->
  <compiler meshdir="meshes" angle="radian" autolimits="true"/>

  <option timestep="0.002" gravity="0 0 -9.81" integrator="RK4"/>

  <visual>
    <headlight ambient="0.4 0.4 0.4" diffuse="0.8 0.8 0.8" specular="0.1 0.1 0.1"/>
  </visual>

  <default>
    <!-- Default joint: light armature for stability -->
    <joint damping="0.7" armature="0.01"/>
    <!-- Visual geoms: no collision -->
    <default class="visual">
      <geom contype="0" conaffinity="0"/>
    </default>
    <!-- Collision geoms: participate in contact -->
    <default class="collision">
      <!-- Arm/head geoms: contype=2 (arm), conaffinity=4 (objects only).
           Collision rules (A·B iff (A.type&B.aff)|(B.type&A.aff) != 0):
             arm(2,4) vs arm(2,4)   → (2&4)|(2&4)=0  — no arm self-collision
             arm(2,4) vs table(1,4) → (2&4)|(1&4)=0  — arm passes through table
             arm(2,4) vs cube(4,5)  → (2&5)|(4&4)=4  — arm hits cube  ✓
      -->
      <geom contype="2" conaffinity="4" rgba="0.4 0.4 0.4 0"/>
    </default>
    <!-- Finger collision geoms: contype=2, conaffinity=5
         finger(2,5) vs cube(4,5)  → (2&5)|(4&5)=0|4=4  — fingers hit cube  ✓
         finger(2,5) vs table(1,4) → (2&4)|(1&5)=0|1=1  — fingers rest on table ✓
         finger(2,5) vs floor(1,4) → (2&4)|(1&5)=0|1=1  — fingers rest on floor ✓
         finger(2,5) vs arm(2,4)   → (2&4)|(2&5)=0|0=0  — no arm self-collision ✓
    -->
    <default class="finger_col">
      <geom contype="2" conaffinity="5" rgba="0.1 0.1 0.1 0" friction="0.8 0.1 0.1"/>
    </default>
  </default>

  <!-- ================================================================
    ASSETS — STL/OBJ meshes + gripper materials
  ================================================================ -->
  <asset>
    <!-- Baxter arm meshes -->
    <mesh name="torso_mesh"    file="torso/base_link.STL"         scale="1 1 1"/>
    <mesh name="pedestal_mesh" file="base/PEDESTAL.STL"           scale="1 1 1"/>
    <mesh name="head_mesh"     file="head/H0.STL"                 scale="1 1 1"/>
    <mesh name="S0"            file="upper_shoulder/S0.STL"       scale="1 1 1"/>
    <mesh name="S1"            file="lower_shoulder/S1.STL"       scale="1 1 1"/>
    <mesh name="E0"            file="upper_elbow/E0.STL"          scale="1 1 1"/>
    <mesh name="E1"            file="lower_elbow/E1.STL"          scale="1 1 1"/>
    <mesh name="W0"            file="upper_forearm/W0.STL"        scale="1 1 1"/>
    <mesh name="W1"            file="lower_forearm/W1.STL"        scale="1 1 1"/>
    <mesh name="W2"            file="wrist/W2.STL"                scale="1 1 1"/>

    <!-- Rethink parallel-jaw gripper meshes -->
    <mesh name="standard_narrow"        file="rethink_gripper/standard_narrow.stl"/>
    <mesh name="half_round_tip"         file="rethink_gripper/half_round_tip.stl"/>
    <mesh name="electric_gripper_base_0" file="rethink_gripper/electric_gripper_base_0.obj"/>
    <mesh name="electric_gripper_base_1" file="rethink_gripper/electric_gripper_base_1.obj"/>
    <mesh name="connector_plate"        file="rethink_gripper/connector_plate.obj"/>

    <!-- Gripper materials -->
    <material name="gripper_mat_dark"   specular="0.5" shininess="0.25" rgba="0.001651 0.001651 0.001651 1"/>
    <material name="gripper_mat_red"    specular="0.5" shininess="0.25" rgba="0.64 0.00 0.00 1"/>
    <material name="gripper_mat_grey"   specular="0.5" shininess="0.25" rgba="0.64 0.64 0.64 1"/>
    <material name="finger_mat"         specular="0.5" shininess="0.25" rgba="0.00 0.00 0.00 1"/>
  </asset>

  <!-- ================================================================
    WORLDBODY
  ================================================================ -->
  <worldbody>

    <!-- ── SCENE CAMERA (world-fixed) ────────────────────────────────────────
         Positioned to the front-right of the workspace, elevated.
         Gives a clear view of the robot, table, and target cube at all times.
    ──────────────────────────────────────────────────────────────────────── -->
    <body name="scene_camera_body" pos="1.0 -1.2 1.2">
      <camera name="scene_camera" xyaxes="0.832 0.555 0  -0.400 0.600 0.693" fovy="55"/>
    </body>

    <!-- Lighting -->
    <light pos="0 0 4"   dir="0 0 -1"    diffuse="0.8 0.8 0.8" specular="0.3 0.3 0.3" castshadow="true"/>
    <light pos="2 2 3"   dir="-1 -1 -1"  diffuse="0.5 0.5 0.5" castshadow="false"/>

    <!-- Floor -->
    <geom name="floor" type="plane" size="5 5 0.1" rgba="0.75 0.75 0.75 1"
          pos="0 0 -0.93" contype="1" conaffinity="4" friction="0.8 0.1 0.1"/>

    <!-- ── TABLE ─────────────────────────────────────────────────────────
         Table top at z = 0.50 m.  Body centre at z=0.475.
    ──────────────────────────────────────────────────────────────────── -->
    <body name="table" pos="0.65 -0.20 0.475">
      <geom name="table_top"  type="box" size="0.25 0.25 0.025"
            rgba="0.55 0.40 0.25 1" contype="1" conaffinity="4"
            friction="0.8 0.1 0.1"/>
      <geom name="table_leg1" type="cylinder" size="0.02 0.69"
            pos=" 0.22  0.22 -0.715" rgba="0.45 0.30 0.20 1"
            contype="0" conaffinity="0"/>
      <geom name="table_leg2" type="cylinder" size="0.02 0.69"
            pos="-0.22  0.22 -0.715" rgba="0.45 0.30 0.20 1"
            contype="0" conaffinity="0"/>
      <geom name="table_leg3" type="cylinder" size="0.02 0.69"
            pos=" 0.22 -0.22 -0.715" rgba="0.45 0.30 0.20 1"
            contype="0" conaffinity="0"/>
      <geom name="table_leg4" type="cylinder" size="0.02 0.69"
            pos="-0.22 -0.22 -0.715" rgba="0.45 0.30 0.20 1"
            contype="0" conaffinity="0"/>
    </body>

    <!-- ── TARGET CUBE ───────────────────────────────────────────────────
         5 cm red cube sitting on the table top (z = 0.525).
         Free joint makes it graspable / pushable.
    ──────────────────────────────────────────────────────────────────── -->
    <body name="target_cube" pos="0.65 -0.40 0.525">
      <joint name="cube_free" type="free"/>
      <inertial pos="0 0 0" mass="0.050" diaginertia="2e-5 2e-5 2e-5"/>
      <geom name="cube" type="box" size="0.025 0.025 0.025"
            rgba="0.9 0.1 0.1 1" contype="4" conaffinity="5"
            friction="0.6 0.1 0.1"/>
    </body>

    <!-- ── BASE / TORSO ─────────────────────────────────────────── -->
    <body name="base" pos="0 0 0">
      <inertial pos="0 0 0" mass="0.001" diaginertia="1e-6 1e-6 1e-6"/>

      <body name="torso" pos="0 0 0">
