                      </body><!-- /left_wrist -->
                    </body><!-- /left_lower_forearm -->
                  </body><!-- /left_upper_forearm -->
                </body><!-- /left_lower_elbow -->
              </body><!-- /left_upper_elbow -->
            </body><!-- /left_lower_shoulder -->
          </body><!-- /left_upper_shoulder -->
        </body><!-- /left_arm_mount -->

      </body><!-- /torso -->
    </body><!-- /base -->
  </worldbody>

  <!-- ================================================================
    ACTUATORS — velocity-controlled, one per DOF.

    kv (Nm·s/rad): approximate servo stiffness.
    ctrlrange: max joint velocity command (rad/s), matching URDF velocity limits.
    Order matches qpos: head_pan, right arm (s0..w2), left arm (s0..w2).
  ================================================================ -->
  <actuator>
    <!-- Head -->
    <velocity name="head_pan_v"  joint="head_pan"  kv="5"  ctrlrange="-1.0 1.0"/>

    <!-- Right arm — shoulder/elbow: vel≤1.5 rad/s; wrist: vel≤4.0 rad/s -->
    <velocity name="right_s0_v"  joint="right_s0"  kv="10" ctrlrange="-1.5 1.5"/>
    <velocity name="right_s1_v"  joint="right_s1"  kv="10" ctrlrange="-1.5 1.5"/>
