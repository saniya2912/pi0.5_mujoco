<!-- ============================================================================
  baxter.xml — MuJoCo MJCF for Baxter robot
  Converted from baxter.urdf (Rethink Robotics).

  Joint tree  (depth-first qpos order):
    [0]  head_pan
    [1]  right_s0  [2] right_s1  [3] right_e0  [4] right_e1
    [5]  right_w0  [6] right_w1  [7] right_w2
    [8]  left_s0   [9] left_s1  [10] left_e0  [11] left_e1
    [12] left_w0  [13] left_w1  [14] left_w2

  Actuators: velocity-controlled, one per DOF (same order).
  Cameras  : head_camera, right_hand_camera, left_hand_camera.
  Keyframe : "home"  — natural bent-arm pose (all within joint limits).
============================================================================ -->
<mujoco model="baxter">

  <!-- meshdir is relative to the location of this XML file (models/) -->
  <compiler meshdir="meshes" angle="radian" autolimits="true"/>

  <option timestep="0.002" gravity="0 0 -9.81" integrator="RK4"/>

  <visual>
    <headlight ambient="0.4 0.4 0.4" diffuse="0.8 0.8 0.8" specular="0.1 0.1 0.1"/>
  </visual>

  <default>
    <!-- Default joint: light armature for stability -->
    <joint damping="0.7" armature="0.01"/>
    <!-- Visual geoms: no collision -->
    <default class="visual">
      <geom contype="0" conaffinity="0"/>
    </default>
    <!-- Collision geoms: participate in contact -->
    <default class="collision">
      <geom contype="1" conaffinity="1" rgba="0.4 0.4 0.4 0"/>
    </default>
  </default>

  <!-- ================================================================
    ASSETS — STL meshes (one per URDF mesh, shared between arms)
  ================================================================ -->
  <asset>
    <mesh name="torso_mesh"    file="torso/base_link.STL"         scale="1 1 1"/>
    <mesh name="pedestal_mesh" file="base/PEDESTAL.STL"           scale="1 1 1"/>
    <mesh name="head_mesh"     file="head/H0.STL"                 scale="1 1 1"/>
    <mesh name="S0"            file="upper_shoulder/S0.STL"       scale="1 1 1"/>
    <mesh name="S1"            file="lower_shoulder/S1.STL"       scale="1 1 1"/>
    <mesh name="E0"            file="upper_elbow/E0.STL"          scale="1 1 1"/>
    <mesh name="E1"            file="lower_elbow/E1.STL"          scale="1 1 1"/>
    <mesh name="W0"            file="upper_forearm/W0.STL"        scale="1 1 1"/>
    <mesh name="W1"            file="lower_forearm/W1.STL"        scale="1 1 1"/>
    <mesh name="W2"            file="wrist/W2.STL"                scale="1 1 1"/>
  </asset>

  <!-- ================================================================
    WORLDBODY
  ================================================================ -->
  <worldbody>

    <!-- ── SCENE CAMERA (world-fixed) ────────────────────────────────────────
         Positioned to the front-right of the workspace, elevated.
         Gives a clear view of the robot, table, and target cube at all times.
    ──────────────────────────────────────────────────────────────────────── -->
    <body name="scene_camera_body" pos="1.0 -1.2 1.2">
      <camera name="scene_camera" xyaxes="0.832 0.555 0  -0.400 0.600 0.693" fovy="55"/>
    </body>

    <!-- Lighting -->
    <light pos="0 0 4"   dir="0 0 -1"    diffuse="0.8 0.8 0.8" specular="0.3 0.3 0.3" castshadow="true"/>
    <light pos="2 2 3"   dir="-1 -1 -1"  diffuse="0.5 0.5 0.5" castshadow="false"/>

    <!-- Floor: Baxter's pedestal bottom sits at ~z=-0.924 m when the robot
         origin is at z=0, so the floor is placed just below that. -->
    <geom name="floor" type="plane" size="5 5 0.1" rgba="0.75 0.75 0.75 1"
          pos="0 0 -0.93" contype="1" conaffinity="1" friction="0.8 0.1 0.1"/>

    <!-- ── TABLE ─────────────────────────────────────────────────────────
         Thin surface placed at a comfortable reach distance in front of
         the right arm.  Table top is at z = 0.30 m.
    ──────────────────────────────────────────────────────────────────── -->
    <!-- Table top at z=0.30 m (robot workspace height).
         Floor is at z=-0.93, so legs span 1.18 m (half=0.59).
         Leg centres at z=-0.615 relative to body → bottoms at z=-0.93. -->
    <body name="table" pos="0.65 -0.20 0.275">
      <geom name="table_top"  type="box" size="0.25 0.25 0.025"
            rgba="0.55 0.40 0.25 1" contype="1" conaffinity="1"
            friction="0.8 0.1 0.1"/>
      <geom name="table_leg1" type="cylinder" size="0.02 0.59"
            pos=" 0.22  0.22 -0.615" rgba="0.45 0.30 0.20 1"
            contype="0" conaffinity="0"/>
      <geom name="table_leg2" type="cylinder" size="0.02 0.59"
            pos="-0.22  0.22 -0.615" rgba="0.45 0.30 0.20 1"
            contype="0" conaffinity="0"/>
      <geom name="table_leg3" type="cylinder" size="0.02 0.59"
            pos=" 0.22 -0.22 -0.615" rgba="0.45 0.30 0.20 1"
            contype="0" conaffinity="0"/>
      <geom name="table_leg4" type="cylinder" size="0.02 0.59"
            pos="-0.22 -0.22 -0.615" rgba="0.45 0.30 0.20 1"
            contype="0" conaffinity="0"/>
    </body>

    <!-- ── TARGET CUBE ───────────────────────────────────────────────────
         5 cm red cube sitting on the table top (z = 0.30 + 0.025 = 0.325).
         Static (welded to world) — acts as the policy's visual target.
         To make it dynamic/graspable, add <joint type="free"/> inside.
    ──────────────────────────────────────────────────────────────────── -->
    <body name="target_cube" pos="0.65 -0.20 0.325">
      <geom name="cube" type="box" size="0.025 0.025 0.025"
            rgba="0.9 0.1 0.1 1" contype="1" conaffinity="1"
            friction="0.8 0.1 0.1"/>
    </body>

    <!-- ── BASE / TORSO ─────────────────────────────────────────── -->
    <!-- Body is welded to world (no free joint defined) -->
    <body name="base" pos="0 0 0">
      <inertial pos="0 0 0" mass="0.001" diaginertia="1e-6 1e-6 1e-6"/>

      <body name="torso" pos="0 0 0">
        <!-- ixx iyy izz ixy ixz iyz  (from URDF ixx ixy ixz iyy iyz izz) -->
        <inertial pos="0 0 0" mass="35.336455"
                  fullinertia="1.849155 1.662671 0.802239 -0.000354 -0.154188 0.003292"/>
        <geom class="visual"    name="torso_v" type="mesh" mesh="torso_mesh" rgba="0.5 0.1 0.1 1"/>
        <geom class="collision" name="torso_c" type="box"  size="0.15 0.15 0.5" pos="0 0 0.35"/>

        <!-- Pedestal: fixed sub-body of torso -->
        <body name="pedestal" pos="0 0 0">
          <inertial pos="0 0 0" mass="60.86397744"
                    fullinertia="5.0635929 6.08689388 4.96191932 0.00103417 0.80199628 0.00105311"/>
          <geom class="visual"    name="pedestal_v" type="mesh" mesh="pedestal_mesh" rgba="0.2 0.2 0.2 1"/>
          <!-- half-height=0.465 → bottom at z=-0.93, flush with floor -->
          <geom class="collision" name="pedestal_c" type="cylinder" size="0.20 0.465" pos="0 0 -0.465"/>
        </body>

        <!-- ── HEAD ─────────────────────────────────────────────── -->
        <!-- URDF joint head_pan: origin xyz="0.06 0 0.686" rpy="0 0 0" axis="0 0 1" -->
        <body name="head" pos="0.06 0 0.686">
          <inertial pos="0 0 0" mass="0.547767"
                    fullinertia="0.004641 0.003295 0.003415 0.000159 0.000242 -0.001324"/>
          <geom class="visual"    name="head_v" type="mesh" mesh="head_mesh" rgba="0.2 0.2 0.2 1"/>
          <geom class="collision" name="head_c" type="sphere" size="0.15" pos="-0.07 0 0.05"/>
          <joint name="head_pan" type="hinge" axis="0 0 1" range="-1.5708 1.5708"/>

          <!-- Head camera body: URDF joint head_camera origin xyz="0.12839 0 0.06368"
               rpy="1.75057 0 1.5708" (parent=head). Camera looks along its -Z in MuJoCo. -->
          <body name="head_camera_body" pos="0.12839 0 0.06368" euler="1.75057 0 1.5708">
            <inertial pos="0 0 0" mass="0.0001" diaginertia="1e-8 1e-8 1e-8"/>
            <camera name="head_camera" pos="0 0 0" fovy="60"/>
          </body>
        </body>

        <!-- ============================================================
          RIGHT ARM
          right_torso_arm_mount: xyz="0.024645 -0.219645 0.118588" rpy="0 0 -0.7854"
        ============================================================ -->
        <body name="right_arm_mount" pos="0.024645 -0.219645 0.118588" euler="0 0 -0.7854">
          <inertial pos="0 0 0" mass="0.0001" diaginertia="1e-8 1e-8 1e-8"/>

          <!-- right_s0: xyz="0.055695 0 0.011038" rpy="0 0 0" axis="0 0 1" -->
          <body name="right_upper_shoulder" pos="0.055695 0 0.011038">
            <inertial pos="0.01783 0.00086 0.19127" mass="5.70044"
                      fullinertia="0.04709102262 0.03766976455 0.03595988478
                                   0.00012787556  0.00614870039  0.00078086899"/>
            <geom class="visual"    name="rus_v" type="mesh"     mesh="S0"    rgba="0.5 0.1 0.1 1"/>
            <geom class="collision" name="rus_c" type="cylinder" size="0.06 0.1361" pos="0 0 0.1361"/>
            <joint name="right_s0" type="hinge" axis="0 0 1" range="-1.7017 1.7017"/>

            <!-- right_s1: xyz="0.069 0 0.27035" rpy="-1.5708 0 0" axis="0 0 1" -->
            <body name="right_lower_shoulder" pos="0.069 0 0.27035" euler="-1.5708 0 0">
              <inertial pos="0.06845 0.00269 -0.00529" mass="3.22698"
                        fullinertia="0.01175209419 0.0278859752 0.02078749298
                                     -0.00030096398 0.00207675762 -0.00018821993"/>
              <geom class="visual"    name="rls_v" type="mesh"     mesh="S1"  rgba="0.5 0.1 0.1 1"/>
              <geom class="collision" name="rls_c" type="cylinder" size="0.06 0.06"/>
              <joint name="right_s1" type="hinge" axis="0 0 1" range="-2.147 1.047"/>

              <!-- right_e0: xyz="0.102 0 0" rpy="1.5708 0 1.5708" axis="0 0 1" -->
              <body name="right_upper_elbow" pos="0.102 0 0" euler="1.5708 0 1.5708">
                <inertial pos="-0.00276 0.00132 0.18086" mass="4.31272"
                          fullinertia="0.02661733557 0.02844355207 0.01248008322
                                       0.00029270634  0.00392189887  0.0010838933"/>
                <geom class="visual"    name="rue_v" type="mesh"     mesh="E0"  rgba="0.5 0.1 0.1 1"/>
                <geom class="collision" name="rue_c" type="cylinder" size="0.06 0.0535" pos="0 0 -0.0535"/>
                <joint name="right_e0" type="hinge" axis="0 0 1" range="-3.0542 3.0542"/>

                <!-- right_e1: xyz="0.069 0 0.26242" rpy="-1.5708 -1.5708 0" axis="0 0 1" -->
                <body name="right_lower_elbow" pos="0.069 0 0.26242" euler="-1.5708 -1.5708 0">
                  <inertial pos="0.02611 0.00159 -0.01117" mass="2.07206"
                            fullinertia="0.00711582686 0.01318227876 0.00926852064
                                         0.00036036173  0.0007459496  -0.00019663418"/>
                  <geom class="visual"    name="rle_v" type="mesh"     mesh="E1"  rgba="0.5 0.1 0.1 1"/>
                  <geom class="collision" name="rle_c" type="cylinder" size="0.06 0.05"/>
                  <joint name="right_e1" type="hinge" axis="0 0 1" range="-0.05 2.618"/>

                  <!-- right_w0: xyz="0.10359 0 0" rpy="1.5708 0 1.5708" axis="0 0 1" -->
                  <body name="right_upper_forearm" pos="0.10359 0 0" euler="1.5708 0 1.5708">
                    <inertial pos="-0.00168 0.0046 0.13952" mass="2.24665"
                              fullinertia="0.01667742825 0.01675457264 0.0037463115
                                           0.00018403705  0.00018657629 -0.00064732352"/>
                    <geom class="visual"    name="ruf_v" type="mesh"     mesh="W0"  rgba="0.5 0.1 0.1 1"/>
                    <geom class="collision" name="ruf_c" type="cylinder" size="0.06 0.044" pos="0 0 -0.044"/>
                    <joint name="right_w0" type="hinge" axis="0 0 1" range="-3.059 3.059"/>

                    <!-- right_w1: xyz="0.01 0 0.2707" rpy="-1.5708 -1.5708 0" axis="0 0 1" -->
                    <body name="right_lower_forearm" pos="0.01 0 0.2707" euler="-1.5708 -1.5708 0">
                      <inertial pos="0.06041 0.00697 0.006" mass="1.60979"
                                fullinertia="0.00387607152 0.00700537914 0.0055275524
                                             -0.00044384784 -0.00021115038  0.00015348067"/>
                      <geom class="visual"    name="rlf_v" type="mesh"     mesh="W1"  rgba="0.5 0.1 0.1 1"/>
                      <geom class="collision" name="rlf_c" type="cylinder" size="0.06 0.05"/>
                      <joint name="right_w1" type="hinge" axis="0 0 1" range="-1.5708 2.094"/>

                      <!-- right_w2: xyz="0.115975 0 0" rpy="1.5708 0 1.5708" axis="0 0 1" -->
                      <body name="right_wrist" pos="0.115975 0 0" euler="1.5708 0 1.5708">
                        <inertial pos="0.00198 0.00125 0.01855" mass="0.35093"
                                  fullinertia="0.00025289155 0.0002688601 0.0003074118
                                               0.00000575311 -0.00000159345 -0.00000519818"/>
                        <geom class="visual"    name="rwr_v" type="mesh"     mesh="W2"  rgba="0.1 0.1 0.1 1"/>
                        <geom class="collision" name="rwr_c" type="cylinder" size="0.06 0.0825"/>
                        <joint name="right_w2" type="hinge" axis="0 0 1" range="-3.059 3.059"/>

                        <!-- right_hand: xyz="0 0 0.11355" fixed -->
                        <body name="right_hand" pos="0 0 0.11355">
                          <inertial pos="0.01093 0.00042 -0.01532" mass="0.19125"
                                    fullinertia="0.00017588 0.00021166377 0.00023745397
                                                 0.00000147073  0.0000243633  0.00000172689"/>
                          <geom class="collision" name="rhand_c" type="cylinder"
                                size="0.04 0.0232" pos="0 0 -0.0232"/>

                          <!-- Right hand camera: positioned 6 cm forward and 4 cm up from
                               right_hand origin, looking along +X of hand frame (sideways/forward).
                               euler="0 1.5708 0" → camera -Z = hand +X direction. -->
                          <body name="right_hand_camera_body"
                                pos="0.06 0 0.04" euler="0 1.5708 0">
                            <inertial pos="0 0 0" mass="0.0001" diaginertia="1e-8 1e-8 1e-8"/>
                            <camera name="right_hand_camera" fovy="90"/>
                          </body>

                          <!-- Right endpoint marker (yellow sphere) -->
                          <body name="right_gripper" pos="0 0 0.025">
                            <inertial pos="0 0 0" mass="0.0001" diaginertia="1e-8 1e-8 1e-8"/>
                            <geom class="visual" name="right_endpoint"
                                  type="sphere" size="0.012" rgba="1 1 0 1"/>
                          </body>
                        </body><!-- /right_hand -->
                      </body><!-- /right_wrist -->
                    </body><!-- /right_lower_forearm -->
                  </body><!-- /right_upper_forearm -->
                </body><!-- /right_lower_elbow -->
              </body><!-- /right_upper_elbow -->
            </body><!-- /right_lower_shoulder -->
          </body><!-- /right_upper_shoulder -->
        </body><!-- /right_arm_mount -->

        <!-- ============================================================
          LEFT ARM
          left_torso_arm_mount: xyz="0.024645 0.219645 0.118588" rpy="0 0 0.7854"
        ============================================================ -->
        <body name="left_arm_mount" pos="0.024645 0.219645 0.118588" euler="0 0 0.7854">
          <inertial pos="0 0 0" mass="0.0001" diaginertia="1e-8 1e-8 1e-8"/>

          <!-- left_s0: identical structure to right_s0 -->
          <body name="left_upper_shoulder" pos="0.055695 0 0.011038">
            <inertial pos="0.01783 0.00086 0.19127" mass="5.70044"
                      fullinertia="0.04709102262 0.03766976455 0.03595988478
                                   0.00012787556  0.00614870039  0.00078086899"/>
            <geom class="visual"    name="lus_v" type="mesh"     mesh="S0"    rgba="0.5 0.1 0.1 1"/>
            <geom class="collision" name="lus_c" type="cylinder" size="0.06 0.1361" pos="0 0 0.1361"/>
            <joint name="left_s0" type="hinge" axis="0 0 1" range="-1.7017 1.7017"/>

            <body name="left_lower_shoulder" pos="0.069 0 0.27035" euler="-1.5708 0 0">
              <inertial pos="0.06845 0.00269 -0.00529" mass="3.22698"
                        fullinertia="0.01175209419 0.0278859752 0.02078749298
                                     -0.00030096398 0.00207675762 -0.00018821993"/>
              <geom class="visual"    name="lls_v" type="mesh"     mesh="S1"  rgba="0.5 0.1 0.1 1"/>
              <geom class="collision" name="lls_c" type="cylinder" size="0.06 0.06"/>
              <joint name="left_s1" type="hinge" axis="0 0 1" range="-2.147 1.047"/>

              <body name="left_upper_elbow" pos="0.102 0 0" euler="1.5708 0 1.5708">
                <inertial pos="-0.00276 0.00132 0.18086" mass="4.31272"
                          fullinertia="0.02661733557 0.02844355207 0.01248008322
                                       0.00029270634  0.00392189887  0.0010838933"/>
                <geom class="visual"    name="lue_v" type="mesh"     mesh="E0"  rgba="0.5 0.1 0.1 1"/>
                <geom class="collision" name="lue_c" type="cylinder" size="0.06 0.0535" pos="0 0 -0.0535"/>
                <joint name="left_e0" type="hinge" axis="0 0 1" range="-3.0542 3.0542"/>

                <body name="left_lower_elbow" pos="0.069 0 0.26242" euler="-1.5708 -1.5708 0">
                  <inertial pos="0.02611 0.00159 -0.01117" mass="2.07206"
                            fullinertia="0.00711582686 0.01318227876 0.00926852064
                                         0.00036036173  0.0007459496  -0.00019663418"/>
                  <geom class="visual"    name="lle_v" type="mesh"     mesh="E1"  rgba="0.5 0.1 0.1 1"/>
                  <geom class="collision" name="lle_c" type="cylinder" size="0.06 0.05"/>
                  <joint name="left_e1" type="hinge" axis="0 0 1" range="-0.05 2.618"/>

                  <body name="left_upper_forearm" pos="0.10359 0 0" euler="1.5708 0 1.5708">
                    <inertial pos="-0.00168 0.0046 0.13952" mass="2.24665"
                              fullinertia="0.01667742825 0.01675457264 0.0037463115
                                           0.00018403705  0.00018657629 -0.00064732352"/>
                    <geom class="visual"    name="luf_v" type="mesh"     mesh="W0"  rgba="0.5 0.1 0.1 1"/>
                    <geom class="collision" name="luf_c" type="cylinder" size="0.06 0.044" pos="0 0 -0.044"/>
                    <joint name="left_w0" type="hinge" axis="0 0 1" range="-3.059 3.059"/>

                    <body name="left_lower_forearm" pos="0.01 0 0.2707" euler="-1.5708 -1.5708 0">
                      <inertial pos="0.06041 0.00697 0.006" mass="1.60979"
                                fullinertia="0.00387607152 0.00700537914 0.0055275524
                                             -0.00044384784 -0.00021115038  0.00015348067"/>
                      <geom class="visual"    name="llf_v" type="mesh"     mesh="W1"  rgba="0.5 0.1 0.1 1"/>
                      <geom class="collision" name="llf_c" type="cylinder" size="0.06 0.05"/>
                      <joint name="left_w1" type="hinge" axis="0 0 1" range="-1.5708 2.094"/>

                      <body name="left_wrist" pos="0.115975 0 0" euler="1.5708 0 1.5708">
                        <inertial pos="0.00198 0.00125 0.01855" mass="0.35093"
