                        <geom class="visual"    name="lwr_v" type="mesh"     mesh="W2"  rgba="0.1 0.1 0.1 1"/>
                        <geom class="collision" name="lwr_c" type="cylinder" size="0.06 0.0825"/>
                        <joint name="left_w2" type="hinge" axis="0 0 1" range="-3.059 3.059"/>

                        <body name="left_hand" pos="0 0 0.11355">
                          <inertial pos="0.01093 0.00042 -0.01532" mass="0.19125"
                                    fullinertia="0.00017588 0.00021166377 0.00023745397
                                                 0.00000147073  0.0000243633  0.00000172689"/>
                          <geom class="collision" name="lhand_c" type="cylinder"
                                size="0.04 0.0232" pos="0 0 -0.0232"/>

                          <!-- Left hand camera: xyz="0.03825 0.012 0.015355" rpy="0 0 -1.5708" -->
                          <body name="left_hand_camera_body"
                                pos="0.03825 0.012 0.015355" euler="0 0 -1.5708">
                            <inertial pos="0 0 0" mass="0.0001" diaginertia="1e-8 1e-8 1e-8"/>
                            <camera name="left_hand_camera" fovy="90"/>
                          </body>

                          <!-- Left endpoint marker (cyan sphere) -->
                          <body name="left_gripper" pos="0 0 0.025">
                            <inertial pos="0 0 0" mass="0.0001" diaginertia="1e-8 1e-8 1e-8"/>
